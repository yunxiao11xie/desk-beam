{
  "C_Cpp.intelliSenseEngine": "default",
  "idf.extensionActivationMode": "always",
  "idf.openOcdConfigs": [
    "board/esp32-wrover-kit-3.3v.cfg"
  ],
  "idf.portWin": "COM_YOUR_PORT",
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32s31"
  },
  "clangd.arguments": [
    "--background-index",
    "--query-driver=**"
  ]
}
